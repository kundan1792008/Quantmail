generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator webClient {
  provider = "prisma-client"
  output   = "../web/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Core Identity ───────────────────────────────────────────────

enum UserRole {
  FREE
  PRO
  USER
  ADMIN
}

enum WebAuthnChallengeType {
  REGISTRATION
  AUTHENTICATION
}

model User {
  id             String         @id @default(uuid())
  displayName    String
  email          String         @unique
  biometricHash  String         @unique
  webAuthnUserId String?        @unique
  verified       Boolean        @default(false)
  role           UserRole       @default(FREE)
  aiCount        Int            @default(0)
  openaiKey      String?
  anthropicKey   String?
  geminiKey      String?
  customModelUrl String?
  customModelKey String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  livenessGrid              LivenessGrid?
  digitalTwin               DigitalTwin?
  sessions                  UserSession[]
  inboxMessages             InboxMessage[]
  saccadeSessions           SaccadeSession[]
  iotDevices                ConnectedIoTDevice[]
  criticalAlerts            CriticalAlert[]
  dashboardLogins           DashboardPhysicalLogin[]
  deviceTokens              DeviceToken[]
  livenessChallenges        LivenessChallenge[]
  pushNotifications         PushNotification[]
  quanttubeWatchEvents      QuanttubeWatchEvent[]
  tasks                     Task[]
  chatMessages              ChatMessage[]
  notes                     Note[]
  emails                    Email[]
  events                    Event[]
  calendarEvents            CalendarEvent[]
  documents                 Document[]
  docs                      Doc[]
  files                     File[]
  sheets                    Sheet[]
  driveFiles                DriveFile[]
  aiSettings                UserAiSettings?
  biometricHashes           BiometricHash[]
  webAuthnChallenges        WebAuthnChallenge[]
  webAuthnCredentials       WebAuthnCredential[]
  sentEphemeralMessages     EphemeralMessage[]   @relation("SentEphemeralMessages")
  messageVaultEntries       MessageVaultEntry[]
}

// ─── AI / BYOK Settings ──────────────────────────────────────────

model UserAiSettings {
  id                String   @id @default(uuid())
  userId            String   @unique
  openaiKey         String?
  anthropicKey      String?
  customModelUrl    String?
  customModelKey    String?
  preferredProvider String   @default("openai")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model LivenessGrid {
  id               String   @id @default(uuid())
  userId           String   @unique
  facialMatrixHash String
  livenessScore    Float
  passed           Boolean
  capturedAt       DateTime @default(now())

  user                User           @relation(fields: [userId], references: [id])
  biometricHashRecord BiometricHash?
}

model BiometricHash {
  id             String   @id @default(uuid())
  userId         String
  livenessGridId String?  @unique
  hash           String   @unique
  source         String   @default("FACIAL_MATRIX")
  algorithm      String   @default("sha256")
  metadata       String   @default("{}")
  createdAt      DateTime @default(now())
  verifiedAt     DateTime?
  revokedAt      DateTime?

  user         User          @relation(fields: [userId], references: [id])
  livenessGrid LivenessGrid? @relation(fields: [livenessGridId], references: [id])

  @@index([userId, createdAt])
}

model WebAuthnChallenge {
  id             String               @id @default(uuid())
  userId         String?
  email          String
  displayName    String?
  biometricHash  String?
  webAuthnUserId String?
  challenge      String               @unique
  type           WebAuthnChallengeType
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime             @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([email, type, createdAt])
  @@index([expiresAt])
}

model DigitalTwin {
  id          String   @id @default(uuid())
  userId      String   @unique
  agentConfig String   @default("{}")
  lastSyncAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ─── Inbox & Shadow Filter ───────────────────────────────────────

model InboxMessage {
  id          String   @id @default(uuid())
  userId      String
  senderEmail String
  subject     String
  body        String
  receivedAt  DateTime @default(now())

  user           User                  @relation(fields: [userId], references: [id])
  criticalAlerts CriticalAlert[]
}

model ShadowInbox {
  id             String   @id @default(uuid())
  senderEmail    String
  recipientEmail String
  subject        String
  body           String
  domain         String
  reason         String   @default("UNVERIFIED_DOMAIN")
  droppedAt      DateTime @default(now())
}

// ─── Saccade Liveness (Quantedits Integration) ───────────────────

model SaccadeSession {
  id              String   @id @default(uuid())
  userId          String
  saccadeHash     String
  sampleCount     Int
  entropyScore    Float
  recordedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── IoT Alarm Orchestration ─────────────────────────────────────

enum AlarmStatus {
  ACTIVE
  SILENCED
  EXPIRED
}

enum DispatchStatus {
  PENDING
  DISPATCHED
  SILENCED
  FAILED
}

enum LoginMethod {
  PHYSICAL
  REMOTE
}

model ConnectedIoTDevice {
  id             String   @id @default(uuid())
  userId         String
  deviceName     String
  platform       String
  connectionType String   @default("WebBluetooth")
  endpointRef    String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user            User            @relation(fields: [userId], references: [id])
  alarmDispatches AlarmDispatch[]

  @@unique([userId, endpointRef, platform], name: "device_unique_identifier")
}

model CriticalAlert {
  id                     String      @id @default(uuid())
  userId                 String
  source                 String
  subject                String
  body                   String
  alarmStatus            AlarmStatus @default(ACTIVE)
  silenceChallenge       String
  triggeredFromMessageId String?
  triggeredAt            DateTime    @default(now())
  silencedAt             DateTime?

  user       User            @relation(fields: [userId], references: [id])
  message    InboxMessage?   @relation(fields: [triggeredFromMessageId], references: [id])
  dispatches AlarmDispatch[]
}

model AlarmDispatch {
  id                    String         @id @default(uuid())
  alertId               String
  deviceId              String
  protocol              String         @default("WEB_BLUETOOTH")
  synchronizedTriggerAt DateTime
  status                DispatchStatus @default(PENDING)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  alert  CriticalAlert      @relation(fields: [alertId], references: [id])
  device ConnectedIoTDevice @relation(fields: [deviceId], references: [id])
}

model DashboardPhysicalLogin {
  id              String      @id @default(uuid())
  userId          String
  dashboardOrigin String
  loginMethod     LoginMethod @default(PHYSICAL)
  deviceProof     String
  expiresAt       DateTime
  createdAt       DateTime    @default(now())
  revokedAt       DateTime?

  user User @relation(fields: [userId], references: [id])
}

// ─── Push Notification Aggressor (QuantAds) ──────────────────────

enum ChallengeStatus {
  PENDING
  SATISFIED
  ESCALATED
  EXPIRED
}

enum NotificationStatus {
  QUEUED
  DISPATCHED
  ACKNOWLEDGED
  FAILED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model LivenessChallenge {
  id               String          @id @default(uuid())
  userId           String
  status           ChallengeStatus @default(PENDING)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  expiresAt        DateTime
  quantadsTarget   String          @default("quantads://campaign/identity-check")
  quantchatTitle   String          @default("Quantchat SDK Warning")
  quantchatBody    String          @default("Biometric liveness token ignored. Open to resolve.")
  escalatedAt      DateTime?
  satisfiedAt      DateTime?
  lastPushAt       DateTime?
  ssoToken         String?

  user          User               @relation(fields: [userId], references: [id])
  notifications PushNotification[]

  @@index([userId])
  @@index([status, createdAt])
}

model PushNotification {
  id              String               @id @default(uuid())
  userId          String
  challengeId     String?
  title           String
  body            String
  payload         String
  priority        NotificationPriority @default(NORMAL)
  status          NotificationStatus   @default(QUEUED)
  channel         String               @default("quantchat-warning")
  createdAt       DateTime             @default(now())
  dispatchedAt    DateTime?
  acknowledgedAt  DateTime?

  user      User                @relation(fields: [userId], references: [id])
  challenge LivenessChallenge?  @relation(fields: [challengeId], references: [id])

  @@index([userId])
  @@index([challengeId])
}

// ─── QuantTube Watch History (Inbox Relevance Sync) ──────────────

model QuanttubeWatchEvent {
  id             String   @id @default(uuid())
  userId         String
  videoTitle     String
  watchedSeconds Int
  watchedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── 9-App Workspace Models ───────────────────────────────────────

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Task {
  id          String       @id @default(uuid())
  userId      String
  title       String
  description String       @default("")
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Email {
  id          String   @id @default(uuid())
  userId      String
  subject     String
  snippet     String   @default("")
  body        String
  date        DateTime @default(now())
  isRead      Boolean  @default(false)
  isStarred   Boolean  @default(false)
  senderId    String
  recipientId String

  user User @relation(fields: [userId], references: [id])
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  channel   String   @default("general")
  content   String
  sentAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Note {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Event {
  id        String   @id @default(uuid())
  userId    String
  title     String
  date      DateTime
  time      String
  attendees String   @default("[]")
  isAI      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])
}

model CalendarEvent {
  id              String   @id @default(uuid())
  userId          String
  title           String
  description     String   @default("")
  startAt         DateTime
  endAt           DateTime
  sourceMessageId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Document {
  id           String   @id @default(uuid())
  userId       String
  title        String
  content      String   @default("")
  lastModified DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Doc {
  id         String   @id @default(uuid())
  userId     String
  title      String
  content    String   @default("")
  sourceType String   @default("manual")
  shareToken String?  @unique
  isPublic   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model File {
  id         String   @id @default(uuid())
  userId     String
  name       String
  type       String
  size       Int
  url        String
  uploadedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Sheet {
  id         String   @id @default(uuid())
  userId     String
  title      String
  data       String   @default("[]")
  shareToken String?  @unique
  isPublic   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model DriveFile {
  id        String   @id @default(uuid())
  userId    String
  name      String
  mimeType  String
  size      Int      @default(0)
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ─── WebAuthn Credentials ─────────────────────────────────────────

model WebAuthnCredential {
  id               String   @id @default(uuid())
  userId           String
  credentialId     String   @unique
  publicKey        String
  counter          BigInt   @default(0)
  deviceType       String   @default("singleDevice")
  backedUp         Boolean  @default(false)
  transports       String   @default("[]")
  aaguid           String   @default("")
  name             String   @default("Passkey")
  createdAt        DateTime @default(now())
  lastUsedAt       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── User Sessions ────────────────────────────────────────────────

model UserSession {
  id             String   @id @default(uuid())
  userId         String
  refreshTokenId String   @unique
  userAgent      String   @default("")
  ip             String   @default("")
  deviceFingerprint String @default("")
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime @default(now())
  lastActiveAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenId])
  @@index([userId, revokedAt])
}

// ─── Webhook Subscriptions ────────────────────────────────────────

model WebhookEndpoint {
  id        String   @id @default(uuid())
  url       String
  secret    String
  events    String   @default("[]")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Admin Global Configuration (BYOK / Custom Model) ────────────

model AdminConfig {
  id                 String   @id @default(uuid())
  globalOpenaiKey    String?
  globalAnthropicKey String?
  globalGeminiKey    String?
  customModelUrl     String?
  customModelKey     String?
  updatedBy          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── Behavioral Biometrics ────────────────────────────────────────

/**
 * Immutable audit trail of every anomaly event generated by the
 * continuous authentication pipeline.  Records are append-only.
 */
model SecurityAuditLog {
  id          String   @id @default(uuid())
  userId      String
  eventType   String
  details     String   @default("{}")
  occurredAt  DateTime @default(now())

  @@index([userId, occurredAt])
  @@index([eventType, occurredAt])
}

// ─── Ephemeral E2E Messages ───────────────────────────────────────

/**
 * Destruction modes for self-destructing messages.
 *
 * READ_ONCE        — message is destroyed after the first successful read.
 * TIMER_1H         — message expires 1 hour after creation.
 * TIMER_24H        — message expires 24 hours after creation.
 * TIMER_7D         — message expires 7 days after creation.
 * SCREENSHOT_PROOF — same as READ_ONCE but also applies CSS/JS anti-capture
 *                    overlays in the SecureReader component.
 */
enum DestructionMode {
  READ_ONCE
  TIMER_1H
  TIMER_24H
  TIMER_7D
  SCREENSHOT_PROOF
}

/**
 * Server-side store for AES-256-GCM encrypted message blobs.
 *
 * The actual decryption key is NEVER stored here.  It lives exclusively
 * in the URL fragment (#key=…) so the server cannot read the content.
 * After destruction, the blob is overwritten with random bytes before
 * the row is deleted.
 */
model EphemeralMessage {
  id              String          @id @default(uuid())
  senderId        String
  recipientEmail  String
  encryptedBlob   Bytes
  iv              String
  authTag         String
  subject         String          @default("")
  destructionMode DestructionMode @default(READ_ONCE)
  screenshotProof Boolean         @default(false)
  expiresAt       DateTime?
  readAt          DateTime?
  destroyedAt     DateTime?
  createdAt       DateTime        @default(now())

  sender  User              @relation("SentEphemeralMessages", fields: [senderId], references: [id])
  keyPair EphemeralKeyPair?

  @@index([recipientEmail])
  @@index([senderId])
  @@index([expiresAt])
}

/**
 * Per-message ECDH key pair record.
 *
 * The server stores only the sender's ephemeral public key so the
 * recipient can derive the shared secret client-side.  The private key
 * is generated client-side and never transmitted.
 *
 * Revoking a key pair makes all messages encrypted with it unreadable
 * (the client can no longer perform the ECDH derivation).
 */
model EphemeralKeyPair {
  id               String    @id @default(uuid())
  messageId        String    @unique
  senderPublicKey  String
  recipientPubKey  String?
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  message EphemeralMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

/**
 * Message Vault — optional long-term storage for ephemeral messages
 * that the original sender explicitly allows to be saved.
 *
 * Protected by WebAuthn biometric unlock.  Hard capped at 100 entries
 * per user; the oldest entry is auto-removed when the cap is reached.
 */
model MessageVaultEntry {
  id                 String   @id @default(uuid())
  userId             String
  ephemeralMessageId String?
  encryptedContent   Bytes
  senderEmail        String
  subject            String
  webAuthnCredId     String
  vaultedAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, vaultedAt])
}
