generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Core Identity ───────────────────────────────────────────────

enum UserRole {
  FREE
  PRO
}

model User {
  id             String         @id @default(uuid())
  displayName    String
  email          String         @unique
  biometricHash  String         @unique
  verified       Boolean        @default(false)
  role           UserRole       @default(FREE)
  aiCount        Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  livenessGrid              LivenessGrid?
  digitalTwin               DigitalTwin?
  inboxMessages             InboxMessage[]
  saccadeSessions           SaccadeSession[]
  iotDevices                ConnectedIoTDevice[]
  criticalAlerts            CriticalAlert[]
  dashboardLogins           DashboardPhysicalLogin[]
  deviceTokens              DeviceToken[]
  livenessChallenges        LivenessChallenge[]
  pushNotifications         PushNotification[]
  quanttubeWatchEvents      QuanttubeWatchEvent[]
  tasks                     Task[]
  chatMessages              ChatMessage[]
  notes                     Note[]
  calendarEvents            CalendarEvent[]
  docs                      Doc[]
  sheets                    Sheet[]
  driveFiles                DriveFile[]
}

model LivenessGrid {
  id               String   @id @default(uuid())
  userId           String   @unique
  facialMatrixHash String
  livenessScore    Float
  passed           Boolean
  capturedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model DigitalTwin {
  id          String   @id @default(uuid())
  userId      String   @unique
  agentConfig String   @default("{}")
  lastSyncAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ─── Inbox & Shadow Filter ───────────────────────────────────────

model InboxMessage {
  id          String   @id @default(uuid())
  userId      String
  senderEmail String
  subject     String
  body        String
  receivedAt  DateTime @default(now())

  user           User                  @relation(fields: [userId], references: [id])
  criticalAlerts CriticalAlert[]
}

model ShadowInbox {
  id             String   @id @default(uuid())
  senderEmail    String
  recipientEmail String
  subject        String
  body           String
  domain         String
  reason         String   @default("UNVERIFIED_DOMAIN")
  droppedAt      DateTime @default(now())
}

// ─── Saccade Liveness (Quantedits Integration) ───────────────────

model SaccadeSession {
  id              String   @id @default(uuid())
  userId          String
  saccadeHash     String
  sampleCount     Int
  entropyScore    Float
  recordedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── IoT Alarm Orchestration ─────────────────────────────────────

enum AlarmStatus {
  ACTIVE
  SILENCED
  EXPIRED
}

enum DispatchStatus {
  PENDING
  DISPATCHED
  SILENCED
  FAILED
}

enum LoginMethod {
  PHYSICAL
  REMOTE
}

model ConnectedIoTDevice {
  id             String   @id @default(uuid())
  userId         String
  deviceName     String
  platform       String
  connectionType String   @default("WebBluetooth")
  endpointRef    String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user            User            @relation(fields: [userId], references: [id])
  alarmDispatches AlarmDispatch[]

  @@unique([userId, endpointRef, platform], name: "device_unique_identifier")
}

model CriticalAlert {
  id                     String      @id @default(uuid())
  userId                 String
  source                 String
  subject                String
  body                   String
  alarmStatus            AlarmStatus @default(ACTIVE)
  silenceChallenge       String
  triggeredFromMessageId String?
  triggeredAt            DateTime    @default(now())
  silencedAt             DateTime?

  user       User            @relation(fields: [userId], references: [id])
  message    InboxMessage?   @relation(fields: [triggeredFromMessageId], references: [id])
  dispatches AlarmDispatch[]
}

model AlarmDispatch {
  id                    String         @id @default(uuid())
  alertId               String
  deviceId              String
  protocol              String         @default("WEB_BLUETOOTH")
  synchronizedTriggerAt DateTime
  status                DispatchStatus @default(PENDING)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  alert  CriticalAlert      @relation(fields: [alertId], references: [id])
  device ConnectedIoTDevice @relation(fields: [deviceId], references: [id])
}

model DashboardPhysicalLogin {
  id              String      @id @default(uuid())
  userId          String
  dashboardOrigin String
  loginMethod     LoginMethod @default(PHYSICAL)
  deviceProof     String
  expiresAt       DateTime
  createdAt       DateTime    @default(now())
  revokedAt       DateTime?

  user User @relation(fields: [userId], references: [id])
}

// ─── Push Notification Aggressor (QuantAds) ──────────────────────

enum ChallengeStatus {
  PENDING
  SATISFIED
  ESCALATED
  EXPIRED
}

enum NotificationStatus {
  QUEUED
  DISPATCHED
  ACKNOWLEDGED
  FAILED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model LivenessChallenge {
  id               String          @id @default(uuid())
  userId           String
  status           ChallengeStatus @default(PENDING)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  expiresAt        DateTime
  quantadsTarget   String          @default("quantads://campaign/identity-check")
  quantchatTitle   String          @default("Quantchat SDK Warning")
  quantchatBody    String          @default("Biometric liveness token ignored. Open to resolve.")
  escalatedAt      DateTime?
  satisfiedAt      DateTime?
  lastPushAt       DateTime?
  ssoToken         String?

  user          User               @relation(fields: [userId], references: [id])
  notifications PushNotification[]

  @@index([userId])
  @@index([status, createdAt])
}

model PushNotification {
  id              String               @id @default(uuid())
  userId          String
  challengeId     String?
  title           String
  body            String
  payload         String
  priority        NotificationPriority @default(NORMAL)
  status          NotificationStatus   @default(QUEUED)
  channel         String               @default("quantchat-warning")
  createdAt       DateTime             @default(now())
  dispatchedAt    DateTime?
  acknowledgedAt  DateTime?

  user      User                @relation(fields: [userId], references: [id])
  challenge LivenessChallenge?  @relation(fields: [challengeId], references: [id])

  @@index([userId])
  @@index([challengeId])
}

// ─── QuantTube Watch History (Inbox Relevance Sync) ──────────────

model QuanttubeWatchEvent {
  id             String   @id @default(uuid())
  userId         String
  videoTitle     String
  watchedSeconds Int
  watchedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── 9-App Workspace Models ───────────────────────────────────────

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Task {
  id          String       @id @default(uuid())
  userId      String
  title       String
  description String       @default("")
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  channel   String   @default("general")
  content   String
  sentAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Note {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model CalendarEvent {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String   @default("")
  startAt     DateTime
  endAt       DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Doc {
  id          String   @id @default(uuid())
  userId      String
  title       String
  content     String   @default("")
  shareToken  String?  @unique
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Sheet {
  id         String   @id @default(uuid())
  userId     String
  title      String
  data       String   @default("[]")
  shareToken String?  @unique
  isPublic   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model DriveFile {
  id        String   @id @default(uuid())
  userId    String
  name      String
  mimeType  String
  size      Int      @default(0)
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}
