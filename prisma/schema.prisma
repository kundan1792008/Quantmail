generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator webClient {
  provider = "prisma-client"
  output   = "../web/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Core Identity ───────────────────────────────────────────────

enum UserRole {
  FREE
  PRO
  USER
  ADMIN
}

enum WebAuthnChallengeType {
  REGISTRATION
  AUTHENTICATION
}

model User {
  id             String         @id @default(uuid())
  displayName    String
  email          String         @unique
  biometricHash  String         @unique
  webAuthnUserId String?        @unique
  verified       Boolean        @default(false)
  role           UserRole       @default(FREE)
  aiCount        Int            @default(0)
  openaiKey      String?
  anthropicKey   String?
  geminiKey      String?
  customModelUrl String?
  customModelKey String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  livenessGrid              LivenessGrid?
  digitalTwin               DigitalTwin?
  sessions                  UserSession[]
  inboxMessages             InboxMessage[]
  saccadeSessions           SaccadeSession[]
  iotDevices                ConnectedIoTDevice[]
  criticalAlerts            CriticalAlert[]
  dashboardLogins           DashboardPhysicalLogin[]
  deviceTokens              DeviceToken[]
  livenessChallenges        LivenessChallenge[]
  pushNotifications         PushNotification[]
  quanttubeWatchEvents      QuanttubeWatchEvent[]
  tasks                     Task[]
  chatMessages              ChatMessage[]
  notes                     Note[]
  emails                    Email[]
  events                    Event[]
  calendarEvents            CalendarEvent[]
  documents                 Document[]
  docs                      Doc[]
  files                     File[]
  sheets                    Sheet[]
  driveFiles                DriveFile[]
  aiSettings                UserAiSettings?

  // Cross-app streak system
  shareStreak               Boolean              @default(false)
  autoConsumeShield         Boolean              @default(false)
  dailyActivities           DailyActivity[]
  streak                    UserStreak?
  streakShields             StreakShield[]
  biometricHashes           BiometricHash[]
  webAuthnChallenges        WebAuthnChallenge[]
  webAuthnCredentials       WebAuthnCredential[]
  ephemeralMessagesSent     EphemeralMessage[]   @relation("EphemeralMessagesSent")
  keyExchangePairs          KeyExchangePair[]    @relation("KeyExchangePairs")
  vaultedMessages           VaultedMessage[]     @relation("VaultedMessages")
}

// ─── AI / BYOK Settings ──────────────────────────────────────────

model UserAiSettings {
  id                String   @id @default(uuid())
  userId            String   @unique
  openaiKey         String?
  anthropicKey      String?
  customModelUrl    String?
  customModelKey    String?
  preferredProvider String   @default("openai")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model LivenessGrid {
  id               String   @id @default(uuid())
  userId           String   @unique
  facialMatrixHash String
  livenessScore    Float
  passed           Boolean
  capturedAt       DateTime @default(now())

  user                User           @relation(fields: [userId], references: [id])
  biometricHashRecord BiometricHash?
}

model BiometricHash {
  id             String   @id @default(uuid())
  userId         String
  livenessGridId String?  @unique
  hash           String   @unique
  source         String   @default("FACIAL_MATRIX")
  algorithm      String   @default("sha256")
  metadata       String   @default("{}")
  createdAt      DateTime @default(now())
  verifiedAt     DateTime?
  revokedAt      DateTime?

  user         User          @relation(fields: [userId], references: [id])
  livenessGrid LivenessGrid? @relation(fields: [livenessGridId], references: [id])

  @@index([userId, createdAt])
}

model WebAuthnChallenge {
  id             String               @id @default(uuid())
  userId         String?
  email          String
  displayName    String?
  biometricHash  String?
  webAuthnUserId String?
  challenge      String               @unique
  type           WebAuthnChallengeType
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime             @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([email, type, createdAt])
  @@index([expiresAt])
}

model DigitalTwin {
  id          String   @id @default(uuid())
  userId      String   @unique
  agentConfig String   @default("{}")
  lastSyncAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ─── Inbox & Shadow Filter ───────────────────────────────────────

model InboxMessage {
  id          String   @id @default(uuid())
  userId      String
  senderEmail String
  subject     String
  body        String
  receivedAt  DateTime @default(now())

  user           User                  @relation(fields: [userId], references: [id])
  criticalAlerts CriticalAlert[]
}

model ShadowInbox {
  id             String   @id @default(uuid())
  senderEmail    String
  recipientEmail String
  subject        String
  body           String
  domain         String
  reason         String   @default("UNVERIFIED_DOMAIN")
  droppedAt      DateTime @default(now())
}

// ─── Self-Destructing Encrypted Messages (Issue #45) ─────────────

enum EphemeralDestructionMode {
  READ_ONCE
  TIMER_1H
  TIMER_24H
  TIMER_7D
  SCREENSHOT_PROOF
}

enum EphemeralMessageState {
  ACTIVE
  READ
  EXPIRED
  DESTROYED
  REVOKED
}

enum KeyExchangeAlgorithm {
  ECDH_P256
  ECDH_P384
}

enum KeyExchangePairState {
  ACTIVE
  ROTATED
  REVOKED
}

/// Encrypted, self-destructing message.
///
/// The server only ever stores opaque ciphertext + AEAD metadata.  The
/// symmetric AES-256-GCM key is generated client-side and embedded in the
/// recipient's URL fragment, so the server cannot decrypt the body.  When the
/// destruction condition is met (single read, timer expiry, or explicit
/// revocation) the ciphertext column is overwritten with random bytes and the
/// row is hard-deleted by `EphemeralMailService.purgeDestroyed`.
model EphemeralMessage {
  id                  String                   @id @default(uuid())
  senderUserId        String
  recipientEmail      String
  subject             String
  ciphertext          String
  iv                  String
  authTag             String
  algorithm           String                   @default("AES-256-GCM")
  destructionMode     EphemeralDestructionMode
  state               EphemeralMessageState    @default(ACTIVE)
  expiresAt           DateTime?
  maxReads            Int                      @default(1)
  readCount           Int                      @default(0)
  senderEphemeralKey  String?
  keyExchangePairId   String?
  vaultAllowed        Boolean                  @default(false)
  attachmentsBlob     String?
  attachmentsIv       String?
  attachmentsAuthTag  String?
  createdAt           DateTime                 @default(now())
  destroyedAt         DateTime?
  destructionReason   String?

  sender       User                        @relation("EphemeralMessagesSent", fields: [senderUserId], references: [id], onDelete: Cascade)
  keyExchange  KeyExchangePair?            @relation(fields: [keyExchangePairId], references: [id])
  deliveries   EphemeralMessageDelivery[]

  @@index([senderUserId, createdAt])
  @@index([recipientEmail, state])
  @@index([state, expiresAt])
}

/// Audit / access record for each open attempt of an EphemeralMessage.
/// Used to enforce READ_ONCE semantics atomically and to surface a
/// tamper-evident access log to the sender.
model EphemeralMessageDelivery {
  id           String   @id @default(uuid())
  messageId    String
  ipHash       String
  userAgent    String   @default("")
  succeeded    Boolean
  reason       String   @default("")
  accessedAt   DateTime @default(now())

  message EphemeralMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, accessedAt])
}

/// Persistent record of an ECDH key pair used for forward-secret messaging.
///
/// A new pair is created per-message (forward secrecy): leaking any single
/// pair's private key never compromises previously sent messages because each
/// message uses an independent shared secret derived via HKDF.  Revoking a
/// pair marks every message that used it as unreadable.
model KeyExchangePair {
  id            String                @id @default(uuid())
  ownerUserId   String
  algorithm     KeyExchangeAlgorithm  @default(ECDH_P256)
  publicKey     String
  privateKey    String
  fingerprint   String                @unique
  state         KeyExchangePairState  @default(ACTIVE)
  label         String                @default("")
  createdAt     DateTime              @default(now())
  rotatedAt     DateTime?
  revokedAt     DateTime?
  expiresAt     DateTime?

  owner    User               @relation("KeyExchangePairs", fields: [ownerUserId], references: [id], onDelete: Cascade)
  messages EphemeralMessage[]

  @@index([ownerUserId, state])
  @@index([state, createdAt])
}

/// A message the sender has explicitly allowed the recipient to retain in
/// their biometric Vault.  The vault is bounded to 100 entries per user –
/// `MessageVault.put` evicts the oldest row when that limit would be exceeded.
model VaultedMessage {
  id              String   @id @default(uuid())
  ownerUserId     String
  originalId      String?
  subject         String
  ciphertext      String
  iv              String
  authTag         String
  algorithm       String   @default("AES-256-GCM")
  wrappedKey      String
  wrappedKeyIv    String
  wrappedKeyTag   String
  savedAt         DateTime @default(now())
  lastAccessedAt  DateTime?
  accessCount     Int      @default(0)

  owner User @relation("VaultedMessages", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, savedAt])
}

// ─── Saccade Liveness (Quantedits Integration) ───────────────────

model SaccadeSession {
  id              String   @id @default(uuid())
  userId          String
  saccadeHash     String
  sampleCount     Int
  entropyScore    Float
  recordedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── IoT Alarm Orchestration ─────────────────────────────────────

enum AlarmStatus {
  ACTIVE
  SILENCED
  EXPIRED
}

enum DispatchStatus {
  PENDING
  DISPATCHED
  SILENCED
  FAILED
}

enum LoginMethod {
  PHYSICAL
  REMOTE
}

model ConnectedIoTDevice {
  id             String   @id @default(uuid())
  userId         String
  deviceName     String
  platform       String
  connectionType String   @default("WebBluetooth")
  endpointRef    String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user            User            @relation(fields: [userId], references: [id])
  alarmDispatches AlarmDispatch[]

  @@unique([userId, endpointRef, platform], name: "device_unique_identifier")
}

model CriticalAlert {
  id                     String      @id @default(uuid())
  userId                 String
  source                 String
  subject                String
  body                   String
  alarmStatus            AlarmStatus @default(ACTIVE)
  silenceChallenge       String
  triggeredFromMessageId String?
  triggeredAt            DateTime    @default(now())
  silencedAt             DateTime?

  user       User            @relation(fields: [userId], references: [id])
  message    InboxMessage?   @relation(fields: [triggeredFromMessageId], references: [id])
  dispatches AlarmDispatch[]
}

model AlarmDispatch {
  id                    String         @id @default(uuid())
  alertId               String
  deviceId              String
  protocol              String         @default("WEB_BLUETOOTH")
  synchronizedTriggerAt DateTime
  status                DispatchStatus @default(PENDING)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  alert  CriticalAlert      @relation(fields: [alertId], references: [id])
  device ConnectedIoTDevice @relation(fields: [deviceId], references: [id])
}

model DashboardPhysicalLogin {
  id              String      @id @default(uuid())
  userId          String
  dashboardOrigin String
  loginMethod     LoginMethod @default(PHYSICAL)
  deviceProof     String
  expiresAt       DateTime
  createdAt       DateTime    @default(now())
  revokedAt       DateTime?

  user User @relation(fields: [userId], references: [id])
}

// ─── Push Notification Aggressor (QuantAds) ──────────────────────

enum ChallengeStatus {
  PENDING
  SATISFIED
  ESCALATED
  EXPIRED
}

enum NotificationStatus {
  QUEUED
  DISPATCHED
  ACKNOWLEDGED
  FAILED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model LivenessChallenge {
  id               String          @id @default(uuid())
  userId           String
  status           ChallengeStatus @default(PENDING)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  expiresAt        DateTime
  quantadsTarget   String          @default("quantads://campaign/identity-check")
  quantchatTitle   String          @default("Quantchat SDK Warning")
  quantchatBody    String          @default("Biometric liveness token ignored. Open to resolve.")
  escalatedAt      DateTime?
  satisfiedAt      DateTime?
  lastPushAt       DateTime?
  ssoToken         String?

  user          User               @relation(fields: [userId], references: [id])
  notifications PushNotification[]

  @@index([userId])
  @@index([status, createdAt])
}

model PushNotification {
  id              String               @id @default(uuid())
  userId          String
  challengeId     String?
  title           String
  body            String
  payload         String
  priority        NotificationPriority @default(NORMAL)
  status          NotificationStatus   @default(QUEUED)
  channel         String               @default("quantchat-warning")
  createdAt       DateTime             @default(now())
  dispatchedAt    DateTime?
  acknowledgedAt  DateTime?

  user      User                @relation(fields: [userId], references: [id])
  challenge LivenessChallenge?  @relation(fields: [challengeId], references: [id])

  @@index([userId])
  @@index([challengeId])
}

// ─── QuantTube Watch History (Inbox Relevance Sync) ──────────────

model QuanttubeWatchEvent {
  id             String   @id @default(uuid())
  userId         String
  videoTitle     String
  watchedSeconds Int
  watchedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── 9-App Workspace Models ───────────────────────────────────────

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Task {
  id          String       @id @default(uuid())
  userId      String
  title       String
  description String       @default("")
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Email {
  id          String   @id @default(uuid())
  userId      String
  subject     String
  snippet     String   @default("")
  body        String
  date        DateTime @default(now())
  isRead      Boolean  @default(false)
  isStarred   Boolean  @default(false)
  senderId    String
  recipientId String

  user User @relation(fields: [userId], references: [id])
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  channel   String   @default("general")
  content   String
  sentAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Note {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Event {
  id        String   @id @default(uuid())
  userId    String
  title     String
  date      DateTime
  time      String
  attendees String   @default("[]")
  isAI      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])
}

model CalendarEvent {
  id              String   @id @default(uuid())
  userId          String
  title           String
  description     String   @default("")
  startAt         DateTime
  endAt           DateTime
  sourceMessageId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Document {
  id           String   @id @default(uuid())
  userId       String
  title        String
  content      String   @default("")
  lastModified DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Doc {
  id         String   @id @default(uuid())
  userId     String
  title      String
  content    String   @default("")
  sourceType String   @default("manual")
  shareToken String?  @unique
  isPublic   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model File {
  id         String   @id @default(uuid())
  userId     String
  name       String
  type       String
  size       Int
  url        String
  uploadedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Sheet {
  id         String   @id @default(uuid())
  userId     String
  title      String
  data       String   @default("[]")
  shareToken String?  @unique
  isPublic   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model DriveFile {
  id        String   @id @default(uuid())
  userId    String
  name      String
  mimeType  String
  size      Int      @default(0)
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ─── WebAuthn Credentials ─────────────────────────────────────────

model WebAuthnCredential {
  id               String   @id @default(uuid())
  userId           String
  credentialId     String   @unique
  publicKey        String
  counter          BigInt   @default(0)
  deviceType       String   @default("singleDevice")
  backedUp         Boolean  @default(false)
  transports       String   @default("[]")
  aaguid           String   @default("")
  name             String   @default("Passkey")
  createdAt        DateTime @default(now())
  lastUsedAt       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── User Sessions ────────────────────────────────────────────────

model UserSession {
  id             String   @id @default(uuid())
  userId         String
  refreshTokenId String   @unique
  userAgent      String   @default("")
  ip             String   @default("")
  deviceFingerprint String @default("")
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime @default(now())
  lastActiveAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenId])
  @@index([userId, revokedAt])
}

// ─── Webhook Subscriptions ────────────────────────────────────────

model WebhookEndpoint {
  id        String   @id @default(uuid())
  url       String
  secret    String
  events    String   @default("[]")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Admin Global Configuration (BYOK / Custom Model) ────────────

model AdminConfig {
  id                 String   @id @default(uuid())
  globalOpenaiKey    String?
  globalAnthropicKey String?
  globalGeminiKey    String?
  customModelUrl     String?
  customModelKey     String?
  updatedBy          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── Cross-App Streak System ──────────────────────────────────────
//
// Positive-engagement streaks across the 9 apps.  Deliberately contains
// no ELO decay, no badge revocation, and no "ghost mode" fields.  Losing
// a streak has no status penalty — the counter simply resets.

enum AppId {
  MAIL
  CALENDAR
  DRIVE
  DOCS
  SHEETS
  NOTES
  TASKS
  CHAT
  MEET
}

enum StreakShieldSource {
  PURCHASE
  PROMO
  COMEBACK_GIFT
  MILESTONE // free shield granted every N streak days
}

/// One record per user per app per UTC calendar day.  Writes are
/// idempotent: recording twice for the same (userId, appId, date) is a
/// no-op (enforced by the composite unique index).
model DailyActivity {
  id        String   @id @default(uuid())
  userId    String
  appId     AppId
  date      DateTime @db.Date
  count     Int      @default(1)
  firstAt   DateTime @default(now())
  lastAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, appId, date], name: "daily_activity_unique")
  @@index([userId, date])
}

/// Aggregate per-user streak state.  Rolled forward by
/// `StreakMaintenanceWorker` and updated transactionally on each
/// activity event.
model UserStreak {
  id                  String    @id @default(uuid())
  userId              String    @unique
  currentStreak       Int       @default(0)
  longestStreak       Int       @default(0)
  lastActiveDate      DateTime? @db.Date
  trinityDays         Int       @default(0) // lifetime count of all-9-apps days
  lastTrinityDate     DateTime? @db.Date
  shieldCount         Int       @default(0) // active shields (cap 2)
  shieldsGrantedTotal Int       @default(0)
  lastMilestoneGrant  Int       @default(0) // last currentStreak at which a milestone shield was granted
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

/// Ledger entry for each shield granted to a user.  A shield is
/// considered "active" while `usedAt` is null.  Holding more than 2
/// active shields is prevented at the service layer.
model StreakShield {
  id          String             @id @default(uuid())
  userId      String
  source      StreakShieldSource
  grantedAt   DateTime           @default(now())
  usedAt      DateTime?
  usedForDate DateTime?          @db.Date
  note        String             @default("")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, usedAt])
}

// ─── Behavioral Biometrics ────────────────────────────────────────

/**
 * Immutable audit trail of every anomaly event generated by the
 * continuous authentication pipeline.  Records are append-only.
 */
model SecurityAuditLog {
  id          String   @id @default(uuid())
  userId      String
  eventType   String
  details     String   @default("{}")
  occurredAt  DateTime @default(now())

  @@index([userId, occurredAt])
  @@index([eventType, occurredAt])
}
