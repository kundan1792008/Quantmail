generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String         @id @default(uuid())
  displayName    String
  email          String         @unique
  biometricHash  String         @unique
  verified       Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  livenessGrid   LivenessGrid?
  digitalTwin    DigitalTwin?
  inboxMessages  InboxMessage[]
  iotDevices     IoTDevice[]
  criticalAlarms CriticalAlarmSession[]
}

model LivenessGrid {
  id               String   @id @default(uuid())
  userId           String   @unique
  facialMatrixHash String
  livenessScore    Float
  passed           Boolean
  capturedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model DigitalTwin {
  id          String   @id @default(uuid())
  userId      String   @unique
  agentConfig String   @default("{}")
  lastSyncAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model InboxMessage {
  id          String   @id @default(uuid())
  userId      String
  senderEmail String
  subject     String
  body        String
  receivedAt  DateTime @default(now())

  user           User                   @relation(fields: [userId], references: [id])
  criticalAlarms CriticalAlarmSession[]
}

model ShadowInbox {
  id             String   @id @default(uuid())
  senderEmail    String
  recipientEmail String
  subject        String
  body           String
  domain         String
  reason         String   @default("UNVERIFIED_DOMAIN")
  droppedAt      DateTime @default(now())
}

enum AlarmStatus {
  ACTIVE
  SILENCED
  EXPIRED
}

model IoTDevice {
  id             String   @id @default(uuid())
  userId         String
  deviceName     String
  platform       String
  connectionType String   @default("WebBluetooth")
  endpointRef    String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id])
  alarmDispatches AlarmDispatch[]

  @@index([userId, active])
}

model CriticalAlarmSession {
  id                    String      @id @default(uuid())
  userId                String
  inboxMessageId        String?
  alertType             String      @default("CRITICAL_PAYMENT_ECOSYSTEM_TOKEN_ALERT")
  status                AlarmStatus @default(ACTIVE)
  triggeredAt           DateTime    @default(now())
  silencedAt            DateTime?
  silencedBy            String?
  silenceOrigin         String?
  requiresPhysicalLogin Boolean     @default(true)

  user        User          @relation(fields: [userId], references: [id])
  inboxMessage InboxMessage? @relation(fields: [inboxMessageId], references: [id])
  dispatches  AlarmDispatch[]

  @@index([userId, status])
}

model AlarmDispatch {
  id             String   @id @default(uuid())
  alarmSessionId String
  deviceId       String
  dispatchedAt   DateTime @default(now())
  acknowledgedAt DateTime?
  channel        String
  status         String   @default("TRIGGERED")
  payload        String   @default("{}")

  alarmSession CriticalAlarmSession @relation(fields: [alarmSessionId], references: [id])
  device       IoTDevice            @relation(fields: [deviceId], references: [id])

  @@index([alarmSessionId])
  @@index([deviceId])
}
