generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  displayName    String?
  masterIdToken  String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  livenessGrid   LivenessGrid?
  digitalTwin    DigitalTwin?
  messages       Message[]
}

model LivenessGrid {
  id              String   @id @default(uuid())
  userId          String   @unique
  facialHash      String   @unique
  livenessScore   Float
  captureMethod   String   @default("capacitor_camera")
  verified        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

model DigitalTwin {
  id          String   @id @default(uuid())
  userId      String   @unique
  agentState  String   @default("{}")
  lastSyncAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model Message {
  id         String   @id @default(uuid())
  userId     String
  sender     String
  subject    String
  body       String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model Shadow {
  id            String   @id @default(uuid())
  senderEmail   String
  senderDomain  String
  recipientId   String
  subject       String
  body          String
  reason        String
  interceptedAt DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  target      String
  details     String
  severity    String   @default("info")
  createdAt   DateTime @default(now())
}
