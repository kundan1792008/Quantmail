generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String         @id @default(uuid())
  displayName    String
  email          String         @unique
  biometricHash  String         @unique
  verified       Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  livenessGrid   LivenessGrid?
  digitalTwin    DigitalTwin?
  inboxMessages  InboxMessage[]
  iotDevices     ConnectedIoTDevice[]
  criticalAlerts CriticalAlert[]
  dashboardLogins DashboardPhysicalLogin[]
}

model LivenessGrid {
  id               String   @id @default(uuid())
  userId           String   @unique
  facialMatrixHash String
  livenessScore    Float
  passed           Boolean
  capturedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model DigitalTwin {
  id          String   @id @default(uuid())
  userId      String   @unique
  agentConfig String   @default("{}")
  lastSyncAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model InboxMessage {
  id          String   @id @default(uuid())
  userId      String
  senderEmail String
  subject     String
  body        String
  receivedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model ShadowInbox {
  id             String   @id @default(uuid())
  senderEmail    String
  recipientEmail String
  subject        String
  body           String
  domain         String
  reason         String   @default("UNVERIFIED_DOMAIN")
  droppedAt      DateTime @default(now())
}

enum DeviceType {
  APPLE_WATCH
  IOT_DEVICE
}

enum AlarmStatus {
  ACTIVE
  SILENCED
}

enum DispatchStatus {
  PENDING
  ACKNOWLEDGED
  SILENCED
}

enum LoginMethod {
  PHYSICAL
}

model ConnectedIoTDevice {
  id                  String     @id @default(uuid())
  userId              String
  deviceName          String
  deviceIdentifier    String
  deviceType          DeviceType
  capacitorDeviceId   String?
  webBluetoothEnabled Boolean    @default(true)
  isActive            Boolean    @default(true)
  lastSeenAt          DateTime   @default(now())
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  user       User           @relation(fields: [userId], references: [id])
  dispatches AlarmDispatch[]

  @@unique([userId, deviceIdentifier])
}

model CriticalAlert {
  id                     String         @id @default(uuid())
  userId                 String
  source                 String
  subject                String
  body                   String
  alarmStatus            AlarmStatus    @default(ACTIVE)
  silenceChallenge       String
  triggeredFromMessageId String?
  triggeredAt            DateTime       @default(now())
  silencedAt             DateTime?

  user       User            @relation(fields: [userId], references: [id])
  dispatches AlarmDispatch[]
}

model AlarmDispatch {
  id                   String         @id @default(uuid())
  alertId              String
  deviceId             String
  protocol             String         @default("WEB_BLUETOOTH")
  synchronizedTriggerAt DateTime
  status               DispatchStatus @default(PENDING)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  alert  CriticalAlert      @relation(fields: [alertId], references: [id])
  device ConnectedIoTDevice @relation(fields: [deviceId], references: [id])
}

model DashboardPhysicalLogin {
  id             String      @id @default(uuid())
  userId         String
  dashboardOrigin String
  loginMethod    LoginMethod @default(PHYSICAL)
  deviceProof    String
  expiresAt      DateTime
  createdAt      DateTime    @default(now())
  revokedAt      DateTime?

  user User @relation(fields: [userId], references: [id])
}
