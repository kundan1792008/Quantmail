generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum ChallengeStatus {
  PENDING
  SATISFIED
  ESCALATED
  EXPIRED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
}

enum NotificationStatus {
  QUEUED
  DISPATCHED
  FAILED
  ACKNOWLEDGED
}

model User {
  id             String         @id @default(uuid())
  displayName    String
  email          String         @unique
  biometricHash  String         @unique
  verified       Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  livenessGrid   LivenessGrid?
  digitalTwin    DigitalTwin?
  inboxMessages  InboxMessage[]
  deviceTokens   DeviceToken[]
  livenessChallenges LivenessChallenge[]
  pushNotifications  PushNotification[]
}

model LivenessGrid {
  id               String   @id @default(uuid())
  userId           String   @unique
  facialMatrixHash String
  livenessScore    Float
  passed           Boolean
  capturedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model DigitalTwin {
  id          String   @id @default(uuid())
  userId      String   @unique
  agentConfig String   @default("{}")
  lastSyncAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model InboxMessage {
  id          String   @id @default(uuid())
  userId      String
  senderEmail String
  subject     String
  body        String
  receivedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model ShadowInbox {
  id             String   @id @default(uuid())
  senderEmail    String
  recipientEmail String
  subject        String
  body           String
  domain         String
  reason         String   @default("UNVERIFIED_DOMAIN")
  droppedAt      DateTime @default(now())
}

model DeviceToken {
  id         String   @id @default(uuid())
  userId     String
  platform   String
  token      String   @unique
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model LivenessChallenge {
  id               String           @id @default(uuid())
  userId           String
  status           ChallengeStatus  @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  expiresAt        DateTime
  quantadsTarget   String           @default("quantads://campaign/identity-check")
  quantchatTitle   String           @default("Quantchat SDK Warning")
  quantchatBody    String           @default("Biometric liveness token ignored. Open to resolve.")
  escalatedAt      DateTime?
  satisfiedAt      DateTime?
  lastPushAt       DateTime?
  ssoToken         String?

  user           User                @relation(fields: [userId], references: [id])
  notifications  PushNotification[]

  @@index([userId])
  @@index([status, createdAt])
}

model PushNotification {
  id              String              @id @default(uuid())
  userId          String
  challengeId     String?
  title           String
  body            String
  payload         String
  priority        NotificationPriority @default(NORMAL)
  status          NotificationStatus   @default(QUEUED)
  channel         String               @default("quantchat-warning")
  createdAt       DateTime             @default(now())
  dispatchedAt    DateTime?
  acknowledgedAt  DateTime?

  user      User             @relation(fields: [userId], references: [id])
  challenge LivenessChallenge? @relation(fields: [challengeId], references: [id])

  @@index([userId])
  @@index([challengeId])
}
