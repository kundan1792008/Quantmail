generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String         @id @default(uuid())
  displayName    String
  email          String         @unique
  biometricHash  String         @unique
  verified       Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  livenessGrid   LivenessGrid?
  digitalTwin    DigitalTwin?
  inboxMessages  InboxMessage[]
  iotDevices     IoTDevice[]
  alarmSessions  AlarmSession[]
  loginSessions  PhysicalLoginSession[]
}

model LivenessGrid {
  id               String   @id @default(uuid())
  userId           String   @unique
  facialMatrixHash String
  livenessScore    Float
  passed           Boolean
  capturedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model DigitalTwin {
  id          String   @id @default(uuid())
  userId      String   @unique
  agentConfig String   @default("{}")
  lastSyncAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model InboxMessage {
  id          String   @id @default(uuid())
  userId      String
  senderEmail String
  subject     String
  body        String
  receivedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  alarmSession AlarmSession?
}

model ShadowInbox {
  id             String   @id @default(uuid())
  senderEmail    String
  recipientEmail String
  subject        String
  body           String
  domain         String
  reason         String   @default("UNVERIFIED_DOMAIN")
  droppedAt      DateTime @default(now())
}

model IoTDevice {
  id                String      @id @default(uuid())
  userId            String
  deviceName        String
  deviceType        IoTDeviceType
  deviceFingerprint String      @unique
  platform          String
  alarmCapable      Boolean     @default(true)
  isConnected       Boolean     @default(true)
  lastSeenAt        DateTime    @default(now())
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user       User                @relation(fields: [userId], references: [id])
  dispatches AlarmDeviceDispatch[]

  @@index([userId, isConnected])
}

model AlarmSession {
  id                String          @id @default(uuid())
  userId            String
  messageId         String?         @unique
  status            AlarmStatus     @default(ACTIVE)
  category          AlarmCategory
  reason            String
  alarmPayload      String          @default("{}")
  triggeredAt       DateTime        @default(now())
  silencedAt        DateTime?
  silencedBySession String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user       User                  @relation(fields: [userId], references: [id])
  message    InboxMessage?         @relation(fields: [messageId], references: [id])
  dispatches  AlarmDeviceDispatch[]

  @@index([userId, status, triggeredAt])
}

model AlarmDeviceDispatch {
  id              String         @id @default(uuid())
  alarmSessionId  String
  iotDeviceId     String
  dispatchStatus  DispatchStatus @default(PENDING)
  commandPayload  String
  dispatchedAt    DateTime       @default(now())
  acknowledgedAt  DateTime?

  alarmSession AlarmSession @relation(fields: [alarmSessionId], references: [id])
  iotDevice    IoTDevice    @relation(fields: [iotDeviceId], references: [id])

  @@unique([alarmSessionId, iotDeviceId])
  @@index([iotDeviceId, dispatchStatus])
}

model PhysicalLoginSession {
  id           String   @id @default(uuid())
  userId       String
  source       String   @default("QUANTCHAT_DASHBOARD_PHYSICAL")
  usedForAlarm Boolean  @default(false)
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  user User @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt, usedForAlarm])
}

enum IoTDeviceType {
  APPLE_WATCH
  IOT_WEBBLUETOOTH
  CAPACITOR_NATIVE
}

enum AlarmStatus {
  ACTIVE
  SILENCED
}

enum AlarmCategory {
  CRITICAL_PAYMENT
  ECOSYSTEM_TOKEN
}

enum DispatchStatus {
  PENDING
  ACKNOWLEDGED
}
