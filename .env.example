# Quantmail Environment Variables
#
# Copy this file to .env and fill in the values before running the server.
# In production, set these as GitHub Secrets (for CI/CD) or environment
# variables on your hosting platform — never commit a populated .env file.

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Fastify server listens on (default: 3000)
PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file used by Prisma (better-sqlite3 adapter).
# In production this should point to a persistent volume path.
DATABASE_URL=file:./prisma/dev.db

# ── Authentication ───────────────────────────────────────────────────────────
# Secret used to sign SSO session tokens.  Use a long, random string (≥ 32 chars).
# Generate one with: openssl rand -base64 32
SSO_SECRET=

# ── Biometric / Liveness ─────────────────────────────────────────────────────
# Which liveness provider to use: "local" | "incode" | "microblink"
LIVENESS_PROVIDER=local

# Required when LIVENESS_PROVIDER=incode
INCODE_API_KEY=

# Required when LIVENESS_PROVIDER=microblink
MICROBLINK_API_KEY=

# ── IoT / Device Auth ────────────────────────────────────────────────────────
# HMAC secret used to verify device proof tokens.  Use a long, random string.
# Generate one with: openssl rand -base64 32
DEVICE_PROOF_HMAC_SECRET=

# ── Push / Real-time ─────────────────────────────────────────────────────────
# Delay (ms) before a synchronized critical-alarm trigger fires (default: 1500)
SYNCHRONIZED_TRIGGER_DELAY_MS=1500
