# ────────────────────────────────────────────────────────────────────────────
# Quantmail – Environment Variable Reference
# Copy this file to .env and fill in the values before running the app.
# NEVER commit .env to version control.
# ────────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=development           # development | production
PORT=3000
LOG_LEVEL=debug                # trace | debug | info | warn | error | fatal

# CORS – comma-separated list of allowed origins (production only)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# PostgreSQL
POSTGRES_USER=quantmail
POSTGRES_PASSWORD=change_me
POSTGRES_DB=quantmail
DATABASE_URL=postgresql://quantmail:change_me@localhost:5432/quantmail

# Redis
REDIS_PASSWORD=change_me
REDIS_URL=redis://:change_me@localhost:6379

# Authentication
SSO_SECRET=quantmail-dev-secret
ENCRYPTION_SECRET=replace_with_a_long_random_secret
NEXT_PUBLIC_WEBAUTHN_RP_ID=quantmail.example.com

# Biometric liveness provider
LIVENESS_PROVIDER=local        # incode | microblink | local
INCODE_API_KEY=
INCODE_API_URL=https://demo-api.incode.com/omni/start
INCODE_FLOW_ID=
MICROBLINK_API_KEY=
MICROBLINK_API_URL=https://api.microblink.com/v1/recognizers/face-liveness
# ── IoT / Device Auth ────────────────────────────────────────────────────────
# HMAC secret used to verify device proof tokens.  Use a long, random string.
# Generate one with: openssl rand -base64 32
DEVICE_PROOF_HMAC_SECRET=

# ── Push / Real-time ─────────────────────────────────────────────────────────
# Delay (ms) before a synchronized critical-alarm trigger fires (default: 1500)
SYNCHRONIZED_TRIGGER_DELAY_MS=1500
