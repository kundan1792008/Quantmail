{
  "name": "quantmail",
  "version": "1.0.0",
  "description": "Quantmail - Biometric Identity Gateway",
  "main": "dist/server.js",
  "scripts": {
    "build": "npx prisma generate && tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit",
