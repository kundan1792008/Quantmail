    "prisma:migrate": "npx prisma migrate dev",
    "deploy": "./deploy.sh"
  },
  "type": "commonjs",
  "dependencies": {
    "@capacitor/camera": "^7.0.2",
    "@capacitor/core": "^7.2.0",
    "@fastify/cors": "^11.2.0",
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "better-sqlite3": "^12.8.0",
    "crypto-js": "^4.2.0",
    "fastify": "^5.8.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^7.6.0",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
